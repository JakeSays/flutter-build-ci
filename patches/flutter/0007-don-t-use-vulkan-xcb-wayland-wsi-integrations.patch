From: Hannes Winkler <hanneswinkler2000@web.de>
Date: Mon, 20 Jan 2025 16:23:24 +0000
Subject: [PATCH] don't use vulkan xcb/wayland WSI integrations

---
 engine/src/build_overrides/vulkan_headers.gni | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/engine/src/build_overrides/vulkan_headers.gni b/engine/src/build_overrides/vulkan_headers.gni
index 5efa8523449..bd1868b21b9 100644
--- a/engine/src/build_overrides/vulkan_headers.gni
+++ b/engine/src/build_overrides/vulkan_headers.gni
@@ -6,6 +6,6 @@
 # set anything.
 
 if (is_linux) {
-  vulkan_use_x11 = true
-  vulkan_use_wayland = true
+  vulkan_use_x11 = false
+  vulkan_use_wayland = false
 }
