From db8402e3597f9efdf57fa215ef3a898aa39edefb Mon Sep 17 00:00:00 2001
From: Hannes Winkler <hanneswinkler2000@web.de>
Date: Thu, 12 Jun 2025 18:50:33 +0200
Subject: [PATCH] fix: unwinding records for Windows -> Linux RISC-V64
 cross-build

According to comments, unwinding records are not used for gen_snapshot.
So we implement them similar to how they're implemented for unsupported
platforms, as no-ops.
---
 runtime/platform/unwinding_records_win.cc | 22 ++++++++++++++++++++++
 1 file changed, 22 insertions(+)

diff --git a/runtime/platform/unwinding_records_win.cc b/runtime/platform/unwinding_records_win.cc
index da871a640cb..3a1ebf81764 100644
--- a/runtime/platform/unwinding_records_win.cc
+++ b/runtime/platform/unwinding_records_win.cc
@@ -15,6 +15,9 @@ namespace dart {
 const intptr_t kReservedUnwindingRecordsSizeBytes = 64;
 #elif defined(TARGET_ARCH_ARM64)
 const intptr_t kReservedUnwindingRecordsSizeBytes = 4 * KB;
+#elif defined(TARGET_ARCH_RISCV64)
+// Same as what "unwinding_records.cc" falls back to on unsupported platforms.
+const intptr_t kReservedUnwindingRecordsSizeBytes = 0;
 #else
 #error Unhandled Windows architecture.
 #endif
@@ -29,6 +32,23 @@ intptr_t UnwindingRecordsPlatform::SizeInBytes() {
 // as it is the only client of these methods (e.g., _not_ in gen_snapshot).
 #if defined(UNWINDING_RECORDS_WINDOWS_HOST)
 
+#if defined(TARGET_ARCH_RISCV64)
+
+// Same as what "unwinding_records.cc" falls back to on unsupported platforms.
+
+void UnwindingRecordsPlatform::RegisterExecutableMemory(
+  void* start,
+  intptr_t size,
+  void** pp_dynamic_table) {}
+void UnwindingRecordsPlatform::RegisterExecutableMemory(
+    void* start,
+    intptr_t size,
+    void* records_start,
+    void** pp_dynamic_table) {}
+void UnwindingRecordsPlatform::UnregisterDynamicTable(void* p_dynamic_table) {}
+
+#else
+
 void UnwindingRecordsPlatform::RegisterExecutableMemory(
     void* start,
     intptr_t size,
@@ -65,6 +85,8 @@ void UnwindingRecordsPlatform::UnregisterDynamicTable(void* p_dynamic_table) {
   RtlDeleteGrowableFunctionTable(p_dynamic_table);
 }
 
+#endif  // defined(TARGET_ARCH_RISCV64) ...
+
 #endif  // defined(UNWINDING_RECORDS_WINDOWS_HOST)
 
 }  // namespace dart
-- 
